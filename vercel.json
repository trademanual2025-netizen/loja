{
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npx prisma generate && next build",
  "crons": [
    {
      "path": "/api/cron/cancel-expired-orders",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/process-whatsapp-queue",
      "schedule": "*/5 * * * *"
    }
  ]
}
